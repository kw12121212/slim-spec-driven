    "@types/node": "^20.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  }
}
